# AstiScale Lead Generation — Environment Variables
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────
# Google Places API — adds extra lead sources (Maps search)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# ── Your contact info ─────────────────────────────────────────────────────────
AGENT_PHONE=+370 600 00000

# ── Email sending (optional — for auto-sending cold emails) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=astiscaleautomation@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ── Lead generation settings ──────────────────────────────────────────────────
LEADS_PER_RUN=30
